{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-tailwindcss"
    ],
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "^21.2.6",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@stomp/stompjs": "^7.3.0",
    "@tailwindcss/postcss": "^4.2.2",
    "phaser": "^3.90.0",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.0",
    "sockjs-client": "^1.6.1",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@types/sockjs-client": "^1.5.4",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^27.1.0",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
